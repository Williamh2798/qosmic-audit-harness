{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditManifest",
  "type": "object",
  "required": ["store_url", "audit_id", "surfaces", "technical_checks"],
  "properties": {
    "store_url": { "type": "string", "format": "uri" },
    "audit_id": { "type": "string", "pattern": "^aud_" },
    "crawled_at": { "type": "string", "format": "date-time" },
    "purchase_model": {
      "type": "string",
      "enum": ["dtc", "retailer_routed", "hybrid", "unknown"]
    },
    "crawl_mode": { "type": "string" },
    "funnel_analytics": { "type": "object" },
    "funnel_steps": { "type": "object" },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "type", "status"],
        "properties": {
          "url": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "homepage",
              "collection",
              "category",
              "pdp",
              "cart",
              "checkout",
              "search",
              "content",
              "where-to-buy",
              "other"
            ]
          },
          "screenshot": { "type": "string" },
          "fold_screenshot": { "type": "string" },
          "mobile_screenshot": { "type": "string" },
          "mobile_fold_screenshot": { "type": "string" },
          "render_source": {
            "type": "string",
            "enum": ["dom", "api_fallback", "geo_blocked"]
          },
          "status": { "type": "integer" },
          "status_note": { "type": "string" },
          "page_url": { "type": "string" },
          "content_verified": { "type": "boolean" },
          "navigation_failure": { "type": "string" },
          "title": { "type": "string" },
          "meta_description": { "type": "string" },
          "text_excerpt": { "type": "string" },
          "above_fold_excerpt": { "type": "string" },
          "h1": { "type": "string" },
          "has_add_to_cart": { "type": "boolean" },
          "has_price": { "type": "boolean" },
          "buy_module": { "type": "object" },
          "trust_signals": { "type": "object" },
          "social_proof": { "type": "object" },
          "structured_data": { "type": "array" },
          "images": { "type": "object" },
          "performance": { "type": "object" },
          "shopify_product": { "type": "object" }
        }
      }
    },
    "technical_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "status", "detail"],
        "properties": {
          "check": { "type": "string" },
          "status": { "type": "string", "enum": ["Pass", "Warn", "Fail"] },
          "detail": { "type": "string" }
        }
      }
    },
    "category_keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "store_insights": {
      "type": "object",
      "properties": {
        "store_name": { "type": "string" },
        "purchase_path_summary": { "type": "string" },
        "top_leaks": { "type": "array", "items": { "type": "string" } },
        "scored_leaks": { "type": "array" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "experiment_seeds": { "type": "array", "items": { "type": "string" } },
        "funnel_health_score": { "type": "integer" },
        "buy_path_completeness": { "type": "integer" }
      }
    }
  }
}
